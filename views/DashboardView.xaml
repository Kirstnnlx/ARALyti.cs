<UserControl x:Class="ARALyti.cs.views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">


    <UserControl.Resources>

        <Style x:Key="CircularProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid Width="{TemplateBinding Width}"
                          Height="{TemplateBinding Height}">

                            <!-- Background Circle -->
                            <Ellipse Stroke="#1E2A59"
                                 StrokeThickness="12"/>

                            <!-- Progress Arc -->
                            <Path x:Name="PART_Track"
                              Stroke="#6A3EFF"
                              StrokeThickness="12"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"/>

                        </Grid>

                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="PART_Track"
                                                     Storyboard.TargetProperty="StrokeDashOffset"
                                                     From="300"
                                                     To="0"
                                                     Duration="0:0:0.8"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>


    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="22"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="22"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="380"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="70"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Hello, Kirsten!"
                               Foreground="White"
                               FontSize="36"
                               FontWeight="Bold"/>
                    <TextBlock Text="Welcome back! Ready to analyze your progress today?"
                               Foreground="#B7C0DD"
                               FontSize="18"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Height="48"
                        Background="#0D1230"
                        BorderBrush="#1E2A59"
                        BorderThickness="1"
                        CornerRadius="24"
                        Margin="0,6,0,0">
                    <TextBox Text="Search topics, projects..."
                             Background="Transparent"
                             Foreground="#B7C0DD"
                             BorderThickness="0"
                             Padding="18,10"
                             VerticalContentAlignment="Center"/>
                </Border>

                <Border Grid.Column="2"
                        Width="50"
                        Height="50"
                        Background="#0D1230"
                        BorderBrush="#1E2A59"
                        BorderThickness="1"
                        CornerRadius="25"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,4,0,0"/>

                <Border Grid.Column="3"
                        Width="54"
                        Height="54"
                        Background="#3B63FF"
                        CornerRadius="27"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,2,0,0"/>
            </Grid>

            <!-- Top cards -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#0D1230"
                        BorderBrush="#1E2A59"
                        BorderThickness="1"
                        CornerRadius="22"
                        Padding="24"
                        Margin="0,0,12,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Grid Width="200" Height="200">
                                <lvc:PieChart x:Name="ProgressChart"
                                              Width="200"
                                              Height="200"
                                              LegendPosition="Hidden"
                                              Background="Transparent"/>

                                <TextBlock x:Name="DashboardProgressText"
                                           Text="0%"
                                           Foreground="White"
                                           FontSize="30"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/> 
                            </Grid>

                            <TextBlock Text="Overall Progress"
                                       Foreground="#B7C0DD"
                                       FontSize="16"
                                       HorizontalAlignment="Center"
                                       Margin="0,28,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="YOUR SKILL OVERVIEW"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>
                            <TextBlock x:Name="DashboardLevelText"
                                       Text="Intermediate"
                                       Foreground="#8E58FF"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Margin="0,26,0,10"/>
                            <TextBlock Text="Keep going! You're making great progress."
                                       Foreground="#B7C0DD"
                                       FontSize="17"
                                       TextWrapping="Wrap"/>

                            <Grid Margin="0,30,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock x:Name="DashboardTotalTopicsCountText"
                                               Text="12"
                                               Foreground="White"
                                               FontSize="28"
                                               FontWeight="Bold"/>  
                                    <TextBlock Text="Total Topics" Foreground="#B7C0DD" FontSize="15"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock x:Name="DashboardProjectsScannedText"
                                               Text="0"
                                               Foreground="White"
                                               FontSize="28"
                                               FontWeight="Bold"/>
                                    <TextBlock Text="Projects&#10;Scanned" Foreground="#B7C0DD" FontSize="15"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock x:Name="DashboardDiaryEntriesText"
                                               Text="0"
                                               Foreground="White"
                                               FontSize="28"
                                               FontWeight="Bold"/>
                                    <TextBlock Text="Diary&#10;Entries" Foreground="#B7C0DD" FontSize="15"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Background="#0D1230"
                        BorderBrush="#1E2A59"
                        BorderThickness="1"
                        CornerRadius="22"
                        Padding="24"
                        Margin="12,0,0,0">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock Text="PROGRESS REPORT"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>
                            <Border Background="#11183A"
                                    CornerRadius="12"
                                    Padding="12,7"
                                    HorizontalAlignment="Right">
                                <TextBlock Text="Last 7 Days"
                                           Foreground="White"
                                           FontSize="14"/>
                            </Border>
                        </DockPanel>

                        <TextBlock Text="Score"
                                   Foreground="#B7C0DD"
                                   FontSize="16"
                                   Margin="0,20,0,10"/>

                        <Rectangle Height="220"
                                   Fill="#131A3D"
                                   RadiusX="16"
                                   RadiusY="16"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Bottom cards -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#0D1230"
                        BorderBrush="#1E2A59"
                        BorderThickness="1"
                        CornerRadius="22"
                        Padding="24"
                        Margin="0,0,12,0">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,18">
                            <TextBlock Text="TOPIC STATUS"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="View All Topics →"
                                       Foreground="#8E58FF"
                                       FontSize="16"
                                       HorizontalAlignment="Right"/>
                        </DockPanel>

                        <StackPanel x:Name="DashboardTopicsPanel"
                                    Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Background="#0D1230"
                        BorderBrush="#1E2A59"
                        BorderThickness="1"
                        CornerRadius="22"
                        Padding="24"
                        Margin="12,0,0,0">
                    <StackPanel>
                        <TextBlock Text="RECOMMENDATION"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <Border Background="#131A3D"
                                CornerRadius="18"
                                Padding="22"
                                Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock x:Name="RecommendationTitleText"
                                           Text="Focus on Recursion"
                                           Foreground="#D14BFF"
                                           FontSize="30"
                                           FontWeight="Bold"/>
                                <TextBlock x:Name="RecommendationDescriptionText"
                                           Text="Practice recursive functions and understand base cases. Try solving factorial or Fibonacci problems."
                                           Foreground="#D4DBF4"
                                           FontSize="17"
                                           TextWrapping="Wrap"
                                           Margin="0,16,0,0"/>
                                <Button Content="View Learning Resources"
                                        Width="230"
                                        Height="48"
                                        Margin="0,26,0,0"
                                        Background="#5B3DF5"
                                        Foreground="White"
                                        BorderThickness="0"
                                        FontSize="16"
                                        FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>