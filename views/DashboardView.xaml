<UserControl x:Class="ARALyti.cs.views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="22"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="22"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="380"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="70"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Hello, Kirsten!"
                               Foreground="White"
                               FontSize="36"
                               FontWeight="Bold"/>
                    <TextBlock Text="Welcome back! Ready to analyze your progress today?"
                               Foreground="#B7C0DD"
                               FontSize="18"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Height="48"
                        Background="#0D1230"
                        BorderBrush="#1E2A59"
                        BorderThickness="1"
                        CornerRadius="24"
                        Margin="0,6,0,0">
                    <TextBox Text="Search topics, projects..."
                             Background="Transparent"
                             Foreground="#B7C0DD"
                             BorderThickness="0"
                             Padding="18,10"
                             VerticalContentAlignment="Center"/>
                </Border>

                <Border Grid.Column="2"
                        Width="50"
                        Height="50"
                        Background="#0D1230"
                        BorderBrush="#1E2A59"
                        BorderThickness="1"
                        CornerRadius="25"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,4,0,0"/>

                <Border Grid.Column="3"
                        Width="54"
                        Height="54"
                        Background="#3B63FF"
                        CornerRadius="27"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,2,0,0"/>
            </Grid>

            <!-- Top cards -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#0D1230"
                        BorderBrush="#1E2A59"
                        BorderThickness="1"
                        CornerRadius="22"
                        Padding="24"
                        Margin="0,0,12,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="230"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Ellipse Width="160" Height="160"
                                     Stroke="#6A3EFF"
                                     StrokeThickness="12"/>
                            <TextBlock x:Name="DashboardProgressText"
                                       Text="58%"
                                       Foreground="White"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,-108,0,0"/>
                            <TextBlock Text="Overall Progress"
                                       Foreground="#B7C0DD"
                                       FontSize="16"
                                       HorizontalAlignment="Center"
                                       Margin="0,28,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="YOUR SKILL OVERVIEW"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>
                            <TextBlock x:Name="DashboardLevelText"
                                       Text="Intermediate"
                                       Foreground="#8E58FF"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Margin="0,26,0,10"/>
                            <TextBlock Text="Keep going! You're making great progress."
                                       Foreground="#B7C0DD"
                                       FontSize="17"/>

                            <Grid Margin="0,30,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock x:Name="DashboardTotalTopicsCountText"
                                               Text="12"
                                               Foreground="White"
                                               FontSize="28"
                                               FontWeight="Bold"/>  
                                    <TextBlock Text="Total Topics" Foreground="#B7C0DD" FontSize="15"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="4" Foreground="White" FontSize="28" FontWeight="Bold"/>
                                    <TextBlock Text="Projects&#10;Scanned" Foreground="#B7C0DD" FontSize="15"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="7" Foreground="White" FontSize="28" FontWeight="Bold"/>
                                    <TextBlock Text="Diary&#10;Entries" Foreground="#B7C0DD" FontSize="15"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="1"
                        Background="#0D1230"
                        BorderBrush="#1E2A59"
                        BorderThickness="1"
                        CornerRadius="22"
                        Padding="24"
                        Margin="12,0,0,0">
                    <StackPanel>
                        <DockPanel>
                            <TextBlock Text="PROGRESS REPORT"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>
                            <Border Background="#11183A"
                                    CornerRadius="12"
                                    Padding="12,7"
                                    HorizontalAlignment="Right">
                                <TextBlock Text="Last 7 Days"
                                           Foreground="White"
                                           FontSize="14"/>
                            </Border>
                        </DockPanel>

                        <TextBlock Text="Score"
                                   Foreground="#B7C0DD"
                                   FontSize="16"
                                   Margin="0,20,0,10"/>

                        <Rectangle Height="220"
                                   Fill="#131A3D"
                                   RadiusX="16"
                                   RadiusY="16"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Bottom cards -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#0D1230"
                        BorderBrush="#1E2A59"
                        BorderThickness="1"
                        CornerRadius="22"
                        Padding="24"
                        Margin="0,0,12,0">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,18">
                            <TextBlock Text="TOPIC STATUS"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="View All Topics →"
                                       Foreground="#8E58FF"
                                       FontSize="16"
                                       HorizontalAlignment="Right"/>
                        </DockPanel>

                        <StackPanel Margin="0,8,0,0">
                            <TextBlock Text="Object-Oriented Programming"
                                       Foreground="White"
                                       FontSize="17"/>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>
                                <ProgressBar Value="85" Maximum="100" Height="10"/>
                                <TextBlock Grid.Column="1" Text="85" Foreground="White" HorizontalAlignment="Center"/>
                                <Border Grid.Column="2" Background="#0B3A33" CornerRadius="12" Padding="10,5">
                                    <TextBlock Text="Strong" Foreground="#45E2A0" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <StackPanel Margin="0,18,0,0">
                            <TextBlock Text="Loops" Foreground="White" FontSize="17"/>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>
                                <ProgressBar Value="70" Maximum="100" Height="10"/>
                                <TextBlock Grid.Column="1" Text="70" Foreground="White" HorizontalAlignment="Center"/>
                                <Border Grid.Column="2" Background="#3A270B" CornerRadius="12" Padding="10,5">
                                    <TextBlock Text="Developing" Foreground="#FFCB47" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <StackPanel Margin="0,18,0,0">
                            <TextBlock Text="Recursion" Foreground="White" FontSize="17"/>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>
                                <ProgressBar Value="20" Maximum="100" Height="10"/>
                                <TextBlock Grid.Column="1" Text="20" Foreground="White" HorizontalAlignment="Center"/>
                                <Border Grid.Column="2" Background="#3A0B2A" CornerRadius="12" Padding="10,5">
                                    <TextBlock Text="Weak" Foreground="#FF5FA5" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <StackPanel Margin="0,18,0,0">
                            <TextBlock Text="Exception Handling" Foreground="White" FontSize="17"/>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>
                                <ProgressBar Value="45" Maximum="100" Height="10"/>
                                <TextBlock Grid.Column="1" Text="45" Foreground="White" HorizontalAlignment="Center"/>
                                <Border Grid.Column="2" Background="#3A270B" CornerRadius="12" Padding="10,5">
                                    <TextBlock Text="Developing" Foreground="#FFCB47" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Background="#0D1230"
                        BorderBrush="#1E2A59"
                        BorderThickness="1"
                        CornerRadius="22"
                        Padding="24"
                        Margin="12,0,0,0">
                    <StackPanel>
                        <TextBlock Text="RECOMMENDATION"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <Border Background="#131A3D"
                                CornerRadius="18"
                                Padding="22"
                                Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock x:Name="RecommendationTitleText"
                                           Text="Focus on Recursion"
                                           Foreground="#D14BFF"
                                           FontSize="30"
                                           FontWeight="Bold"/>
                                <TextBlock x:Name="RecommendationDescriptionText"
                                           Text="Practice recursive functions and understand base cases. Try solving factorial or Fibonacci problems."
                                           Foreground="#D4DBF4"
                                           FontSize="17"
                                           TextWrapping="Wrap"
                                           Margin="0,16,0,0"/>
                                <Button Content="View Learning Resources"
                                        Width="230"
                                        Height="48"
                                        Margin="0,26,0,0"
                                        Background="#5B3DF5"
                                        Foreground="White"
                                        BorderThickness="0"
                                        FontSize="16"
                                        FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>