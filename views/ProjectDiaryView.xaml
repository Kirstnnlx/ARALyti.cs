<UserControl x:Class="ARALyti.cs.views.ProjectDiaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="380"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="70"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Hello, Kirsten!"
                               Foreground="White"
                               FontSize="36"
                               FontWeight="Bold"/>
                    <TextBlock Text="Review your learning journey and reflect on your progress."
                               Foreground="#B7C0DD"
                               FontSize="18"
                               Margin="0,8,0,0"/>
                </StackPanel>

                
                <Border Grid.Column="2" Width="50" Height="50" Background="#0D1230" BorderBrush="#1E2A59" BorderThickness="1" CornerRadius="25" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,4,0,0"/>
                <Border Grid.Column="3" Width="54" Height="54" Background="#3B63FF" CornerRadius="27" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,2,0,0"/>
            </Grid>

            <!-- top cards -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.75*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="0.75*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1.5*"/>
                </Grid.ColumnDefinitions>

                <!-- Total Entries -->
                <Border Grid.Column="0"
                        Background="#080D28"
                        BorderBrush="#171F54"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="40" Height="40"
                                Background="#4B2EFF"
                                CornerRadius="7"
                                VerticalAlignment="Top">
                            <TextBlock Text="🗃️"
                                       Foreground="White"
                                       FontSize="22"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="TOTAL ENTRIES"
                                       Foreground="White"
                                       FontSize="15"
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="TotalEntriesText"
                                       Text="0"
                                       Foreground="White"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Margin="0,2,0,2"/>
                            <TextBlock Text="Across all projects"
                                       Foreground="#8B95B8"
                                       FontSize="13"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- This Week -->
                <Border Grid.Column="2"
                        Background="#080D28"
                        BorderBrush="#171F54"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="40" Height="40"
                                Background="#4B2EFF"
                                CornerRadius="7"
                                VerticalAlignment="Top">
                            <TextBlock Text="📂"
                                       Foreground="White"
                                       FontSize="24"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="THIS WEEK"
                                       Foreground="White"
                                       FontSize="15"
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="ThisWeekEntriesText"
                                       Text="0"
                                       Foreground="White"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Margin="0,2,0,2"/>
                            <TextBlock Text="Diary entries logged"
                                       Foreground="#8B95B8"
                                       FontSize="13"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Most Active Project -->
                <Border Grid.Column="4"
                        Background="#080D28"
                        BorderBrush="#171F54"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="40" Height="40"
                                Background="#4B2EFF"
                                CornerRadius="7"
                                VerticalAlignment="Top">
                            <TextBlock Text="📈"
                                       Foreground="White"
                                       FontSize="21"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="MOST ACTIVE PROJECT"
                                       Foreground="White"
                                       FontSize="15"
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="MostActiveProjectText"
                                       Text="No Project"
                                       Foreground="White"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Margin="0,4,0,4"
                                       TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis"
                                       MaxHeight="52"/>
                            <TextBlock x:Name="MostActiveProjectCountText"
                                       Text="0 entries"
                                       Foreground="#8B95B8"
                                       FontSize="13"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- diary area -->
            <Border Grid.Row="4"
                    Background="#0D1230"
                    BorderBrush="#1E2A59"
                    BorderThickness="1"
                    CornerRadius="22"
                    Padding="24">
                <StackPanel>
                    <TextBlock Text="PROJECT DIARY"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"/>
                    <TextBlock Text="Browse your learning journey grouped by project."
                               Foreground="#B7C0DD"
                               FontSize="15"
                               Margin="0,6,0,18"/>

                    <ComboBox x:Name="ProjectSelectorComboBox"
                              Height="40"
                              Margin="0,0,0,10"
                              HorizontalAlignment="Stretch"
                              Background="#131A3D"
                              Foreground="#0D1230"
                              BorderBrush="#1E2A59"
                              BorderThickness="1"
                              Padding="8">

                        <ComboBox.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#131A3D"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="White"/>
                        </ComboBox.Resources>

                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Background" Value="#131A3D"/>
                                <Setter Property="Padding" Value="6"/>
                            </Style>
                        </ComboBox.ItemContainerStyle>

                    </ComboBox>

                    <TextBox x:Name="DiaryInputTextBox"
                             Height="100"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             Background="#131A3D"
                             Foreground="White"
                             BorderBrush="#1E2A59"
                             BorderThickness="1"
                             Padding="12"
                             Margin="0,0,0,10"
                             Tag="Write your diary entry here..."
                             Loaded="DiaryInputTextBox_Loaded"
                             GotFocus="DiaryInputTextBox_GotFocus"
                             LostFocus="DiaryInputTextBox_LostFocus"/>

                    <Button x:Name="SaveEntryButton"
                               Content="Save Entry"
                               Height="42"
                               Width="150"
                               HorizontalAlignment="Left"
                               Background="#5B3DF5"
                               Foreground="White"
                               BorderThickness="0"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Click="SaveEntryButton_Click"/>

                    <StackPanel x:Name="DiaryEntriesPanel"
                               Margin="0,20,0,0"/>

                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>