<UserControl x:Class="ARALyti.cs.views.TopicsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="380"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="70"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Hello, Kirsten!"
                               Foreground="White"
                               FontSize="36"
                               FontWeight="Bold"/>
                    <TextBlock Text="Browse all tracked topics and monitor your progress."
                               Foreground="#B7C0DD"
                               FontSize="18"
                               Margin="0,8,0,0"/>
                </StackPanel>


                <Border Grid.Column="2" Width="50" Height="50" Background="#0D1230" BorderBrush="#1E2A59" BorderThickness="1" CornerRadius="25" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,4,0,0"/>
                <Border Grid.Column="3" Width="54" Height="54" Background="#3B63FF" CornerRadius="27" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,2,0,0"/>
            </Grid>

            <!-- summary cards -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total Topics -->
                <Border Grid.Column="0"
                        Background="#080D28"
                        BorderBrush="#171F54"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,12,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="44"
                                Height="44"
                                Background="#4B2EFF"
                                CornerRadius="6"
                                VerticalAlignment="Top" Margin="2,0,10,0">
                            <TextBlock Text="📖"
                                       FontSize="25"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Top"/>
                        </Border>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="TOTAL TOPICS"
                                       Foreground="White"
                                       FontSize="15"
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="TotalTopicsText"
                                       Text="0"
                                       Foreground="White"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Margin="0,2,0,2"/>
                            <TextBlock Text="Tracked in your progress"
                                       Foreground="#8B95B8"
                                       FontSize="11"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Strong -->
                <Border Grid.Column="1"
                        Background="#080D28"
                        BorderBrush="#171F54"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="●  STRONG"
                                   Foreground="#45E2A0"
                                   FontSize="15"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="StrongCountText"
                                   Text="0"
                                   Foreground="White"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Margin="18,2,0,2"/>
                        <TextBlock x:Name="StrongPercentText"
                                   Text="0.0% of your topics"
                                   Foreground="#8B95B8"
                                   FontSize="11"
                                   Margin="18,0,0,0"/>
                        
                    </StackPanel>
                </Border>

                <!-- Developing -->
                <Border Grid.Column="2"
                        Background="#080D28"
                        BorderBrush="#171F54"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="●  DEVELOPING"
                                   Foreground="#FFCB47"
                                   FontSize="15"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="DevelopingCountText"
                                   Text="0"
                                   Foreground="White"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Margin="18,2,0,2"/>
                        <TextBlock x:Name="DevelopingPercentText"
                                   Text="0.0% of your topics"
                                   Foreground="#8B95B8"
                                   FontSize="11"
                                   Margin="18,0,0,0"/>  
                    </StackPanel>
                </Border>

                <!-- Weak -->
                <Border Grid.Column="3"
                        Background="#080D28"
                        BorderBrush="#171F54"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel>
                        <TextBlock Text="●  WEAK"
                                   Foreground="#FF5FA5"
                                   FontSize="15"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="WeakCountText"
                                   Text="0"
                                   Foreground="White"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Margin="18,2,0,2"/>
                        <TextBlock x:Name="WeakPercentText"
                                   Text="0.0% of your topics"
                                   Foreground="#8B95B8"
                                   FontSize="11"
                                   Margin="18,0,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- table-like area -->
            <Border Grid.Row="4"
                    Background="#0D1230"
                    BorderBrush="#1E2A59"
                    BorderThickness="1"
                    CornerRadius="22"
                    Padding="24">
                <StackPanel>
                    <DockPanel Margin="0,0,0,18">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="ALL TOPICS" Foreground="White" FontSize="20" FontWeight="Bold"/>
                            <TextBlock Text="View and filter all topics based on your analysis."
                                       Foreground="#B7C0DD"
                                       FontSize="15"
                                       Margin="0,6,0,0"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Filter"
                                    Width="100"
                                    Height="40"
                                    Margin="0,0,12,0"
                                    Background="#131A3D"
                                    Foreground="White"
                                    BorderBrush="#1E2A59"/>
                            <Button Content="Sort: Name (A - Z)"
                                    Width="180"
                                    Height="40"
                                    Background="#131A3D"
                                    Foreground="White"
                                    BorderBrush="#1E2A59"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- header row -->
                    <Border Background="#11183A" CornerRadius="14" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="TOPIC ID" Foreground="#D8E0FF" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="1" Text="TOPIC" Foreground="#D8E0FF" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="2" Text="DIFFICULTY" Foreground="#D8E0FF" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="3" Text="STATUS" Foreground="#D8E0FF" FontWeight="SemiBold"/>
                            <TextBlock Grid.Column="4" Text="SCORE" Foreground="#D8E0FF" FontWeight="SemiBold"/>
                        </Grid>
                    </Border>

                    <!-- rows -->
                    <StackPanel x:Name="TopicsPanel" Margin="0,1,0,0"/>

                    <TextBlock x:Name="TopicsFooterText"
                               Text="Showing 0 topics"
                               Foreground="#B7C0DD"
                               FontSize="14"
                               Margin="0,16,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>