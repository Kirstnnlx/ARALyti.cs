<UserControl x:Class="ARALyti.cs.views.ScanProjectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:ARALyti.cs"
             mc:Ignorable="d"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="18"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="70"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="HelloUserText"
                               Text="Hello, User!"
                               Foreground="White"
                               FontSize="36"
                               FontWeight="Bold"/>
                    <TextBlock Text="Scan your C# project to analyze your skills."
                               Foreground="#B7C0DD"
                               FontSize="18"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,14,8,0">

                    <TextBlock x:Name="StreakDaysText"
                               Text="0"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"/>

                    <Image Source="/Frontend/Assets/streak.png"
                           Width="35"
                           Height="35"
                           Stretch="Uniform"/>
                </StackPanel>

                <Button Grid.Column="2"
                        Width="60"
                        Height="60"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,2,0,0"
                        Cursor="Hand"
                        Click="ProfileButton_Click">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Image Source="/Frontend/Assets/user_icon.png"
                                   Width="60"
                                   Height="60"
                                   Stretch="Uniform"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>


            </Grid>

            <StackPanel Grid.Row="1">
            </StackPanel>

            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1.7*"/>
                </Grid.ColumnDefinitions>

                <!-- Left Upload Area -->
                <Border Grid.Column="0"
                        Background="#15103F"
                        BorderBrush="#6B42FF"
                        BorderThickness="1"
                        CornerRadius="22"
                        Padding="24"
                        Margin="0,0,12,0" RenderTransformOrigin="0.497,0.455">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image Source="/Frontend/Assets/folder.png"
                               Width="100"
                               Height="80"
                               Stretch="Uniform"
                               Margin="0,0,0,0"/>

                        <TextBlock Text="Upload C# File"
                                   Foreground="White"
                                   FontSize="23"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,10"/>

                        <TextBlock Text="Drag and drop your .cs file here&#10;or click to browse"
                                   Foreground="#B7C0DD"
                                   FontSize="12"
                                   TextAlignment="Center"
                                   Margin="0,0,0,16"/>

                        <Button x:Name="ChooseFileButton"
                                Content="Choose File"
                                Width="160"
                                Height="46"
                                Background="#5B3DF5"
                                Foreground="White"
                                FontWeight="SemiBold"
                                BorderThickness="0"
                                Click="ChooseFileButton_Click"/>
                    </StackPanel>
                </Border>

                <!-- Right Selected File Area -->
                <Border Grid.Column="1"
                        Background="#0D1230"
                        BorderBrush="#1E2A59"
                        BorderThickness="1"
                        CornerRadius="22"
                        Padding="24"
                        Margin="12,0,0,0">
                    <StackPanel>
                        <TextBlock Text="SELECTED FILE"
                                   Foreground="#B7C0DD"
                                   FontSize="16"/>

                        <Border Background="#11183A"
                                CornerRadius="16"
                                Padding="18"
                                Margin="0,14,0,28">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="56"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Image Source="/Frontend/Assets/csharp.png"
                                       Width="42"
                                       Height="42"
                                       Stretch="Uniform"
                                       VerticalAlignment="Center"/> 

                                <StackPanel Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Margin="10,0,0,0">
                                    <TextBlock x:Name="FileNameText"
                                               Text="No file selected"
                                               Foreground="White"
                                               FontSize="20"
                                               FontWeight="Bold"/>

                                    <TextBlock x:Name="SelectedFileText"
                                               Text="No file selected"
                                               Foreground="#B7C0DD"
                                               FontSize="15"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Grid>

                        </Border>

                        <Button x:Name="StartScanningButton"
                                Content="Start Scanning"
                                Width="190"
                                Height="48"
                                HorizontalAlignment="Center"
                                Background="#5B3DF5"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="14"
                                FontWeight="SemiBold"
                                Click="StartScanningButton_Click"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Bottom Area -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#0D1230"
                        BorderBrush="#1E2A59"
                        BorderThickness="1"
                        CornerRadius="22"
                        Padding="24"
                        Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="📇 SCAN RESULTS"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Topics Detected"
                                   Foreground="White"
                                   FontSize="25"
                                   FontWeight="Bold"
                                   Margin="0,13,0,8"/>
                        <TextBlock Text="Programming concepts identified from your uploaded C# file."
                                   Foreground="#9BA7D1"
                                   FontSize="15"/>

                        <StackPanel x:Name="DetectedTopicsPanel" 
                                    Margin="0,26,0,0"/>


                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Background="#0D1230"
                        BorderBrush="#1E2A59"
                        BorderThickness="1"
                        CornerRadius="22"
                        Padding="24"
                        Margin="12,0,0,0">
                    <StackPanel>
                        <TextBlock Text="📑 CODE PREVIEW"
                                   Foreground="White"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <Border Background="#090E27"
                                CornerRadius="16"
                                Padding="18"
                                Margin="0,18,0,0">
                            <TextBlock x:Name="CodePreviewText"
                                       Foreground="#D8E0FF"
                                       FontFamily="Consolas"
                                       FontSize="14"
                                       TextWrapping="Wrap"
                                       Text="Code preview will appear here..."/>

                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
