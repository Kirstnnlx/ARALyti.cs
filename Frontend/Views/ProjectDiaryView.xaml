<UserControl x:Class="ARALyti.cs.views.ProjectDiaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:ARALyti.cs"
             mc:Ignorable="d"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="Transparent">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="70"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="HelloUserText"
                                Text="Hello, User!"
                                Foreground="White"
                                FontSize="36"
                                FontWeight="Bold"/>
                    <TextBlock Text="Review your learning journey and reflect on your progress."
                               Foreground="#B7C0DD"
                               FontSize="18"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,14,8,0">

                    <TextBlock x:Name="StreakDaysText"
                               Text="0"
                               Foreground="#8E58FF"
                               FontSize="18"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"/>

                    <Image Source="/Frontend/Assets/streak.png"
                           Width="35"
                           Height="35"
                           Stretch="Uniform"/>
                </StackPanel>

                <Button Grid.Column="2"
                        Width="60"
                        Height="60"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,2,0,0"
                        Cursor="Hand"
                        Click="ProfileButton_Click">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Image Source="/Frontend/Assets/user_icon.png"
                                   Width="60"
                                   Height="60"
                                   Stretch="Uniform"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>


            </Grid>

            <!-- top cards -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total Entries -->
                <Border Grid.Column="0"
                        Background="#080D28"
                        BorderBrush="#171F54"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="40" Height="40"
                                Background="#4B2EFF"
                                CornerRadius="7"
                                VerticalAlignment="Top">
                            <TextBlock Text="🗃️"
                                       Foreground="White"
                                       FontSize="22"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="TOTAL ENTRIES"
                                       Foreground="White"
                                       FontSize="15"
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="TotalEntriesText"
                                       Text="0"
                                       Foreground="White"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Margin="0,2,0,2"/>
                            <TextBlock Text="Across all projects"
                                       Foreground="#8B95B8"
                                       FontSize="13"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- This Week -->
                <Border Grid.Column="2"
                        Background="#080D28"
                        BorderBrush="#171F54"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="40" Height="40"
                                Background="#4B2EFF"
                                CornerRadius="7"
                                VerticalAlignment="Top">
                            <TextBlock Text="📂"
                                       Foreground="White"
                                       FontSize="24"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="THIS WEEK"
                                       Foreground="White"
                                       FontSize="15"
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="ThisWeekEntriesText"
                                       Text="0"
                                       Foreground="White"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Margin="0,2,0,2"/>
                            <TextBlock Text="Diary entries logged"
                                       Foreground="#8B95B8"
                                       FontSize="13"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Most Active Project -->
                <Border Grid.Column="4"
                        Background="#080D28"
                        BorderBrush="#171F54"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="56"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="40" Height="40"
                                Background="#4B2EFF"
                                CornerRadius="7"
                                VerticalAlignment="Top">
                            <TextBlock Text="📈"
                                       Foreground="White"
                                       FontSize="21"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="MOST ACTIVE PROJECT"
                                       Foreground="White"
                                       FontSize="15"
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="MostActiveProjectText"
                                       Text="No Project"
                                       Foreground="White"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Margin="0,4,0,4"
                                       TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis"
                                       MaxHeight="52"/>
                            <TextBlock x:Name="MostActiveProjectCountText"
                                       Text="0 entries"
                                       Foreground="#8B95B8"
                                       FontSize="13"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- diary area -->
            <Border Grid.Row="4"
                    Background="#080D28" 
                    BorderBrush="#1E2A59"
                    BorderThickness="1"
                    CornerRadius="22"
                    Padding="24">
                <StackPanel>
                    <TextBlock Text="PROJECT DIARY"
                               Foreground="White"
                               FontSize="20"
                               FontWeight="Bold"/>
                    <TextBlock Text="Browse your learning journey grouped by project."
                               Foreground="#B7C0DD"
                               FontSize="15"
                               Margin="0,6,0,4"/>

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Write Entry Panel -->
                        <Border Background="#11183A"
                                CornerRadius="16"
                                Padding="18">
                            <StackPanel>
                                <TextBlock Text="WRITE ENTRY"
                                           Foreground="White"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Margin="0,4,0,14"/>

                                <Grid Margin="0,0,0,12">

                                    <ComboBox x:Name="ProjectSelectorComboBox"
                                              Height="42"
                                              Background="#131A3D"
                                              Foreground="White"
                                              BorderBrush="#1E2A59"
                                              BorderThickness="1"
                                              Padding="8"
                                              SelectionChanged="ProjectSelectorComboBox_SelectionChanged">

                                        <ComboBox.Style>
                                            <Style TargetType="ComboBox">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ComboBox">
                                                            <Grid>
                                                                <Border Background="White"
                                                                        BorderBrush="#3D52B0"
                                                                        BorderThickness="1"
                                                                        CornerRadius="8">
                                                                    <Grid>
                                                                        <ContentPresenter x:Name="ContentSite"
                                                                                          IsHitTestVisible="False"
                                                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                                                          Margin="10,0,30,0"
                                                                                          VerticalAlignment="Center"
                                                                                          TextBlock.Foreground="Black"/>
                                                                        <TextBlock x:Name="PlaceholderText"
                                                                                   Text="Select a project..."
                                                                                   Foreground="#8B95B8"
                                                                                   Margin="10,0,0,0"
                                                                                   VerticalAlignment="Center"
                                                                                   IsHitTestVisible="False"
                                                                                   Visibility="Collapsed"/>
                                                                        <ToggleButton Focusable="False"
                                                                                      IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                                                      Background="Transparent"
                                                                                      BorderThickness="0"
                                                                                      HorizontalAlignment="Stretch"
                                                                                      VerticalAlignment="Stretch">
                                                                            <ToggleButton.Template>
                                                                                <ControlTemplate TargetType="ToggleButton">
                                                                                    <Border Background="Transparent">
                                                                                        <Path Data="M 0 0 L 6 6 L 12 0"
                                                                                              Stroke="#6B7BB8"
                                                                                              StrokeThickness="2"
                                                                                              HorizontalAlignment="Right"
                                                                                              VerticalAlignment="Center"
                                                                                              Margin="0,0,12,0"/>
                                                                                    </Border>
                                                                                </ControlTemplate>
                                                                            </ToggleButton.Template>
                                                                        </ToggleButton>
                                                                    </Grid>
                                                                </Border>
                                                                <Popup x:Name="Popup"
                                                                       Placement="Bottom"
                                                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                                                       AllowsTransparency="True"
                                                                       Focusable="False"
                                                                       PopupAnimation="Slide">
                                                                    <Border Background="#222D65"
                                                                            BorderBrush="#3D52B0"
                                                                            BorderThickness="1"
                                                                            CornerRadius="8"
                                                                            MinWidth="{TemplateBinding ActualWidth}"
                                                                            MaxHeight="200">
                                                                        <ScrollViewer>
                                                                            <ItemsPresenter/>
                                                                        </ScrollViewer>
                                                                    </Border>
                                                                </Popup>
                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="SelectedIndex" Value="-1">
                                                                    <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ComboBox.Style>

                                        <ComboBox.Resources>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#131A3D"/>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="White"/>
                                        </ComboBox.Resources>

                                        <ComboBox.ItemContainerStyle>
                                            <Style TargetType="ComboBoxItem">
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="Background" Value="#131A3D"/>
                                                <Setter Property="Padding" Value="6"/>
                                            </Style>
                                        </ComboBox.ItemContainerStyle>

                                    </ComboBox>


                                </Grid>

                                <TextBox x:Name="DiaryInputTextBox"
                                         Height="120"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         Background="#131A3D"
                                         Foreground="White"
                                         BorderBrush="#1E2A59"
                                         BorderThickness="3"
                                         Padding="12"
                                         Margin="0,0,0,14"
                                         Tag="Write your diary entry here..."
                                         Loaded="DiaryInputTextBox_Loaded"
                                         GotFocus="DiaryInputTextBox_GotFocus"
                                         LostFocus="DiaryInputTextBox_LostFocus"/>

                                <Button x:Name="SaveEntryButton"
                                        Content="Save Entry"
                                        Height="42"
                                        Width="150"
                                        HorizontalAlignment="Left"
                                        Background="#5B3DF5"
                                        Foreground="White"
                                        BorderThickness="0"
                                        FontSize="15"
                                        FontWeight="SemiBold"
                                        Cursor="Hand"
                                        Click="SaveEntryButton_Click">

                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                CornerRadius="14">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Border>

                    </Grid>

                    
                    <StackPanel x:Name="DiaryEntriesPanel"
                               Margin="0,20,0,0"/>

                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>