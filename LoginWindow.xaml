<Window x:Class="ARALyti.cs.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ARALyti.cs" Width="400" Height="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="SingleBorderWindow" 
        Background="#0A0E28" Foreground="White"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="PlaceholderBrush" Color="Gray"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#0096FF"/>
        <SolidColorBrush x:Key="CardBackground" Color="#0F1437"/>
        <SolidColorBrush x:Key="ButtonBrush" Color="#783CDC"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#DC3C3C"/>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ButtonBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4" 
                                Padding="10,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#8E4EFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title and Subtitle -->
        <StackPanel Grid.Row="0" Margin="0,30,0,0">
            <TextBlock Text="ARALyti.cs" FontSize="22" FontWeight="Bold" 
                       HorizontalAlignment="Center" Foreground="White"/>
            <TextBlock Text="Study and Project Intelligence System" FontSize="9" 
                       Foreground="#9696C8" HorizontalAlignment="Center" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Card Panel -->
        <Border Grid.Row="1" Width="300" Height="180" 
                Background="{StaticResource CardBackground}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                HorizontalAlignment="Center" VerticalAlignment="Center">

            <Grid Margin="17,15,17,15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="What's your name?" 
                           Foreground="#9696C8" FontSize="9" Margin="0,0,0,8"/>

                <!-- IMPORTANT: txtName -->
                <TextBox x:Name="txtName" Grid.Row="1" 
                         Height="28" FontSize="10"
                         Background="#191E46" BorderBrush="#2A2E66"
                         Foreground="{StaticResource PlaceholderBrush}"
                         CaretBrush="White"
                         Margin="0,0,0,10"/>

                <!-- IMPORTANT: lblError -->
                <Label x:Name="lblError" Grid.Row="2" 
                       Content="" Foreground="{StaticResource ErrorBrush}"
                       FontSize="9" Padding="0,0,0,5" Visibility="Collapsed"/>

                <!-- IMPORTANT: btnStart -->
                <Button x:Name="btnStart" Grid.Row="3" 
                        Content="Get Started →" 
                        Style="{StaticResource ModernButton}"
                        HorizontalAlignment="Stretch" Height="36"
                        IsDefault="True"/>
            </Grid>
        </Border>
        
        <TextBlock x:Name="txtQuote" Grid.Row="2" 
                   Foreground="#646496" FontSize="8" FontStyle="Italic"
                   TextAlignment="Center" TextWrapping="Wrap"
                   Margin="25,0,25,20" HorizontalAlignment="Center"
                   MaxWidth="350"/>
    </Grid>
</Window>