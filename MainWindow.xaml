<Window x:Class="ARALyti.cs.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:ARALyti.cs.views"
        mc:Ignorable="d"
        Title="ARALyti.cs"
        Height="860"
        Width="1520"
        WindowStartupLocation="CenterScreen"
        Background="#050816">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#060A1F">
            <Grid Margin="22,22,22,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Row="0"
                            Margin="6,8,6,28"
                            HorizontalAlignment="Center">

                    <Image Source="/Assets/logo.png"
                           Height="70"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Menu -->
                <StackPanel Grid.Row="1"
            Margin="0,10,0,0">

                    <!-- Dashboard -->
                    <Button x:Name="DashboardButton"
                            Height="50"
                            Margin="0,0,0,10"
                            Background="Transparent"
                            Foreground="#C7D2FE"
                            BorderThickness="0"
                            HorizontalContentAlignment="Left"
                            Padding="38,0,0,0"
                            Click="DashboardButton_Click">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="14">
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="  💻"
                                       FontSize="16"
                                       Width="40"
                                       VerticalAlignment="Center"/>

                            <TextBlock Text="Dashboard"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Scan Project -->
                    <Button x:Name="ScanProjectButton"
                            Height="50"
                            Margin="0,0,0,10"
                            Background="Transparent"
                            Foreground="#C7D2FE"
                            BorderThickness="0"
                            HorizontalContentAlignment="Left"
                            Padding="38,0,0,0"
                            Click="ScanProjectButton_Click">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="14">
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="  📁"
                                       FontSize="16"
                                       Width="40"
                                       VerticalAlignment="Center"/>

                            <TextBlock Text="Scan Project"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Topics -->
                    <Button x:Name="TopicsButton"
                            Height="50"
                            Margin="0,0,0,10"
                            Background="Transparent"
                            Foreground="#C7D2FE"
                            BorderThickness="0"
                            HorizontalContentAlignment="Left"
                            Padding="38,0,0,0"
                            Click="TopicsButton_Click">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="14">
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="  📖"
                                       FontSize="16"
                                       Width="40"
                                       VerticalAlignment="Center"/>

                            <TextBlock Text="Topics"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Project Diary -->
                    <Button x:Name="ProjectDiaryButton"
                            Height="50"
                            Margin="0,0,0,10"
                            Background="Transparent"
                            Foreground="#C7D2FE"
                            BorderThickness="0"
                            HorizontalContentAlignment="Left"
                            Padding="38,0,0,0"
                            Click="ProjectDiaryButton_Click">

                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="14">
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="  📝"
                                       FontSize="16"
                                       Width="40"
                                       VerticalAlignment="Center"/>

                            <TextBlock Text="Project Diary"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

                <!-- Motivation section -->
                <Grid Grid.Row="2"
                      VerticalAlignment="Bottom"
                      Margin="-22,20,-22,60">
 
                    <StackPanel Grid.Row="2"
                            VerticalAlignment="Bottom"
                            Margin="0,20,0,60">

                        <Image Source="/Assets/arko.png"
                           Width="235"
                           HorizontalAlignment="Left"
                           Margin="-3,-24,0,-32"/>

                    </StackPanel>


                    <!-- Small floating card -->
                    <Border Width="190"
                            Height="60"
                            Background="#111734"
                            BorderBrush="#1E2A59"
                            BorderThickness="1"
                            CornerRadius="16"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,-45"
                            Padding="12,8">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Rocket -->
                            <Image Source="/Assets/rocket.png"
                                   Width="34"
                                   Height="34"
                                   VerticalAlignment="Center"/>

                            <!-- Text -->
                            <TextBlock Grid.Column="1"
                                       Text="Scan projects and track your progress"
                                       Foreground="White"
                                       FontSize="10.5"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"
                                       Margin="6,0,0,0"/>
                        </Grid>
                    </Border>

                </Grid>

                <TextBlock Grid.Row="3"
                           Text="ARALyti.cs v1.0.0"
                           Foreground="#8B95B8"
                           FontSize="12"
                           Margin="0,14,0,14"
                           HorizontalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Column="1" Background="#050816">
            <views:DashboardView x:Name="DashboardPanel" Visibility="Visible"/>
            <views:ScanProjectView x:Name="ScanProjectPanel" Visibility="Collapsed"/>
            <views:TopicsView x:Name="TopicsPanel" Visibility="Collapsed"/>
            <views:ProjectDiaryView x:Name="ProjectDiaryPanel" Visibility="Collapsed"/>
        </Grid>
    </Grid>
</Window>