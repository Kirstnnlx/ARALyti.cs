<Window x:Class="ARALyti.cs.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:ARALyti.cs.views"
        mc:Ignorable="d"
        Title="ARALyti.cs"
        Height="860"
        Width="1520"
        WindowStartupLocation="CenterScreen"
        Background="#050816">


    <Grid Background="#050816">


 <!-- LOGIN PAGE -->
        <Grid x:Name="LoginPage">

            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#050816" Offset="0"/>
                    <GradientStop Color="#0A1030" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>


            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="0.9*"/>
            </Grid.ColumnDefinitions>

    <!-- Left Side -->
    <Grid Grid.Column="0"
          VerticalAlignment="Center"
          Margin="130,0,60,0">

        <StackPanel HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Width="560">

            <!-- Logo -->
            <Image Source="/Frontend/Assets/logo.png"
                   Width="390"
                   HorizontalAlignment="Left"
                   Margin="0,0,0,24"/>

            <!-- Headline -->
            <TextBlock Foreground="White"
                       FontSize="37"
                       FontWeight="Bold"
                       TextWrapping="Wrap"
                       Margin="0,0,0,10">
                <Run Text="Your C# Learning"/>
                <LineBreak/>
                <Run Text="Journey Starts Here."/>
            </TextBlock>

            <TextBlock Text="Scan your projects, track your topics, and grow as a developer."
                       Foreground="#7B8EC8"
                       FontSize="16"
                       TextWrapping="Wrap"
                       Margin="0,0,0,36"/>

            <!-- Feature highlights -->
            <StackPanel Margin="0,0,0,8">

                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Border Background="#1A1147"
                            BorderBrush="#3B2A8A"
                            BorderThickness="1"
                            CornerRadius="12"
                            Width="42" Height="42"
                            Margin="0,0,14,0">
                        <TextBlock Text="📁"
                                   Foreground="White"
                                   FontSize="16"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Scan C# Projects"
                                   Foreground="White"
                                   FontSize="14"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Detect topics and concepts automatically"
                                   Foreground="#5A6A9A"
                                   FontSize="12"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Border Background="#1A1147"
                            BorderBrush="#3B2A8A"
                            BorderThickness="1"
                            CornerRadius="12"
                            Width="42" Height="42"
                            Margin="0,0,14,0">
                        <TextBlock Text="📈"
                                   Foreground="White"
                                   FontSize="16"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Track Your Progress"
                                   Foreground="White"
                                   FontSize="14"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Visualize growth with charts and insights"
                                   Foreground="#5A6A9A"
                                   FontSize="12"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <Border Background="#1A1147"
                            BorderBrush="#3B2A8A"
                            BorderThickness="1"
                            CornerRadius="12"
                            Width="42" Height="42"
                            Margin="0,0,14,0">
                        <TextBlock Text="📝"
                                   Foreground="White"
                                   FontSize="16"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Log Your Journey"
                                   Foreground="White"
                                   FontSize="14"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Keep a diary of what you've built and learned"
                                   Foreground="#5A6A9A"
                                   FontSize="12"/>
                    </StackPanel>
                </StackPanel>

            </StackPanel>
        </StackPanel>
    </Grid>

    <!-- Right Login Card — gradient border wrapper -->
    <Border Grid.Column="1"
            Width="460"
            VerticalAlignment="Center"
            HorizontalAlignment="Center"
            CornerRadius="24"
            Padding="2">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#2A1F6B" Offset="0"/>
                <GradientStop Color="#1A2560" Offset="0.5"/>
                <GradientStop Color="#2A1F6B" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

                <Border CornerRadius="23"
                        Padding="42">

                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#0D1230" Offset="0"/>
                            <GradientStop Color="#0A0D24" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>

                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="30"
                            ShadowDepth="0"
                            Color="#000000"
                            Opacity="0.35"/>
                    </Border.Effect>


            <StackPanel>



                <TextBlock Text="Get Started"
                           Foreground="White"
                           FontSize="32"
                           FontWeight="Bold"
                           Margin="0,8,0,10"/>

                <TextBlock Text="Enter your name to continue to your dashboard."
                           Foreground="#7B8EC8"
                           FontSize="14"
                           Margin="0,0,0,28"
                           TextWrapping="Wrap"/>

                <TextBlock Text="Your Nickname"
                           Foreground="#7B8EC8"
                           FontSize="13"
                           FontWeight="Bold"
                           Margin="0,0,0,8"/>

                <!-- Input field -->
                <Border Background="#131A3D"
                        BorderBrush="#2A3570"
                        BorderThickness="1"
                        CornerRadius="12"
                        Margin="0,0,0,6">
                    <TextBox x:Name="LoginNameTextBox"
                             MaxLength="25"
                             Height="52"
                             Background="Transparent"
                             Foreground="White"
                             BorderThickness="0"
                             Padding="14,0"
                             FontSize="15.5"
                             CaretBrush="White"
                             VerticalContentAlignment="Center"/>
                </Border>

                <TextBlock x:Name="LoginErrorText"
                           Text="Please enter your name."
                           Foreground="#FF5FA5"
                           FontSize="13"
                           Visibility="Collapsed"
                           Margin="0,8,0,0"/>

                <!-- Button -->
                <Button Content="Enter Dashboard"
                        Height="50"
                        Margin="0,28,0,0"
                        Background="#5B3DF5"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="LoginButton_Click">
                            <Button.Style>
                                <Style TargetType="Button">

                                    <Setter Property="Background" Value="#5B3DF5"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderThickness" Value="0"/>

                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="14">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>

                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#6D52FF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
            </StackPanel>
        </Border>
    </Border>

</Grid>


        <Grid x:Name="AppShell" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="270"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="#060A1F">
                <Grid Margin="22,22,22,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Logo -->
                    <StackPanel Grid.Row="0"
                            Margin="6,8,6,28"
                            HorizontalAlignment="Center">

                        <Image Source="/Frontend/Assets/logo.png"
                           Height="70"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Menu -->
                    <StackPanel Grid.Row="1"
            Margin="0,10,0,0">

                        <!-- Dashboard -->
                        <Button x:Name="DashboardButton"
                            Height="50"
                            Margin="0,0,0,10"
                            Background="Transparent"
                            Foreground="#C7D2FE"
                            BorderThickness="0"
                            HorizontalContentAlignment="Left"
                            Padding="38,0,0,0"
                            Click="DashboardButton_Click">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                        CornerRadius="14">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="  💻"
                                       FontSize="16"
                                       Width="40"
                                       VerticalAlignment="Center"/>

                                <TextBlock Text="Dashboard"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Scan Project -->
                        <Button x:Name="ScanProjectButton"
                            Height="50"
                            Margin="0,0,0,10"
                            Background="Transparent"
                            Foreground="#C7D2FE"
                            BorderThickness="0"
                            HorizontalContentAlignment="Left"
                            Padding="38,0,0,0"
                            Click="ScanProjectButton_Click">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                        CornerRadius="14">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="  📁"
                                       FontSize="16"
                                       Width="40"
                                       VerticalAlignment="Center"/>

                                <TextBlock Text="Scan Project"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Topics -->
                        <Button x:Name="TopicsButton"
                            Height="50"
                            Margin="0,0,0,10"
                            Background="Transparent"
                            Foreground="#C7D2FE"
                            BorderThickness="0"
                            HorizontalContentAlignment="Left"
                            Padding="38,0,0,0"
                            Click="TopicsButton_Click">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                        CornerRadius="14">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="  📖"
                                       FontSize="16"
                                       Width="40"
                                       VerticalAlignment="Center"/>

                                <TextBlock Text="Topics"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Project Diary -->
                        <Button x:Name="ProjectDiaryButton"
                            Height="50"
                            Margin="0,0,0,10"
                            Background="Transparent"
                            Foreground="#C7D2FE"
                            BorderThickness="0"
                            HorizontalContentAlignment="Left"
                            Padding="38,0,0,0"
                            Click="ProjectDiaryButton_Click">

                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                        CornerRadius="14">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="  📝"
                                       FontSize="16"
                                       Width="40"
                                       VerticalAlignment="Center"/>

                                <TextBlock Text="Project Diary"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>

                    <!-- Motivation section -->
                    <Border Grid.Row="2"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,16"
                            CornerRadius="20"
                            Padding="1.5">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#2A1F6B" Offset="0"/>
                                <GradientStop Color="#1E2A59" Offset="0.5"/>
                                <GradientStop Color="#2A1F6B" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>

                        <Border CornerRadius="19">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0D1230" Offset="0"/>
                                    <GradientStop Color="#130D2E" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>

                            <StackPanel Margin="18,20,18,20">

                                <!-- Glow orb + rocket -->
                                <Grid HorizontalAlignment="Center"
                                      Width="110"
                                      Height="110"
                                      Margin="0,0,0,14">

                                    <Ellipse Width="110"
                                             Height="110"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center">
                                        <Ellipse.Fill>
                                            <RadialGradientBrush>
                                                <GradientStop Color="#4B2EFF" Offset="0"/>
                                                <GradientStop Color="#00000000" Offset="1"/>
                                            </RadialGradientBrush>
                                        </Ellipse.Fill>
                                    </Ellipse>

                                    <Image Source="/Frontend/Assets/rocket.png"
                                           Width="100"
                                           Height="100"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Accent divider line -->
                                <Border Height="2"
                                        CornerRadius="2"
                                        Margin="20,0,20,14">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                            <GradientStop Color="#00000000" Offset="0"/>
                                            <GradientStop Color="#6B42FF" Offset="0.5"/>
                                            <GradientStop Color="#00000000" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>

                                <!-- Pill tag -->
                                <Border Background="#1A1147"
                                        BorderBrush="#3B2A8A"
                                        BorderThickness="1"
                                        CornerRadius="20"
                                        Padding="10,4"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,10">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="6"
                                                 Height="6"
                                                 Fill="#6B42FF"
                                                 VerticalAlignment="Center"
                                                 Margin="0,0,6,0"/>
                                        <TextBlock Text="Active Learner"
                                                   Foreground="#8E6FFF"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>

                                <!-- Heading -->
                                <TextBlock Text="Keep Coding!"
                                           Foreground="White"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,6"/>

                                <!-- Subtitle -->
                                <TextBlock Text="Scan projects and track your progress."
                                           Foreground="#6B7BB8"
                                           FontSize="11.5"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           HorizontalAlignment="Center"/>

                            </StackPanel>
                        </Border>
                    </Border>

                    <TextBlock Grid.Row="3"
                           Text="ARALyti.cs v1.0.0"
                           Foreground="#8B95B8"
                           FontSize="12"
                           Margin="0,14,0,14"
                           HorizontalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Content -->
            <Grid Grid.Column="1" Background="#050816">

                <views:DashboardView x:Name="DashboardPanel" Visibility="Visible"/>
                <views:ScanProjectView x:Name="ScanProjectPanel" Visibility="Collapsed"/>
                <views:TopicsView x:Name="TopicsPanel" Visibility="Collapsed"/>
                <views:ProjectDiaryView x:Name="ProjectDiaryPanel" Visibility="Collapsed"/>

                <Popup x:Name="ProfilePopup"
                       Placement="Bottom"
                       StaysOpen="False"
                       AllowsTransparency="True"
                       PopupAnimation="Fade"
                       VerticalOffset="10">

                    <Border Width="330"
                            Background="#0D1230"
                            BorderBrush="White"
                            BorderThickness="1"
                            CornerRadius="20"
                            Padding="20"
                            Margin="0,10,0,0">

                        <StackPanel>
                            <Grid>
                                <TextBlock Text="User Information"
                                           Foreground="White"
                                           FontSize="20"
                                           FontWeight="Bold"/>

                                <Button Content="×"
                                        Width="28"
                                        Height="28"
                                        HorizontalAlignment="Right"
                                        Background="Transparent"
                                        Foreground="#B7C0DD"
                                        BorderThickness="0"
                                        FontSize="20"
                                        Click="CloseProfilePopup_Click"/>
                            </Grid>

                            <Border Height="1"
                                    Background="#1E2A59"
                                    Margin="0,14,0,16"/>

                            <Border Background="#11183A"
                                    CornerRadius="16"
                                    Padding="16">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="14"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="14"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="36"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0">
                                        <TextBlock Text="Name"
                                                   Foreground="#B7C0DD"
                                                   FontSize="13"
                                                   Margin="0,0,0,6"/>
                                        <Border Background="#0D1230"
                                                CornerRadius="12"
                                                Padding="12,9">
                                            <TextBlock x:Name="ProfileNameText"
                                                       Text="🙋🏻 Name"
                                                       Foreground="White"
                                                       FontSize="16"/>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Row="2">
                                        <TextBlock Text="Skill Level"
                                                   Foreground="#B7C0DD"
                                                   FontSize="13"
                                                   Margin="0,0,0,6"/>
                                        <Border Background="#0D1230"
                                                CornerRadius="12"
                                                Padding="12,9">
                                            <TextBlock x:Name="ProfileSkillLevelText"
                                                       Text="🏅 Beginner"
                                                       Foreground="White"
                                                       FontSize="16"/>
                                        </Border>
                                    </StackPanel>

                                    <StackPanel Grid.Row="4">
                                        <TextBlock Text="Date Joined"
                                                   Foreground="#B7C0DD"
                                                   FontSize="13"
                                                   Margin="0,0,0,6"/>
                                        <Border Background="#0D1230"
                                                CornerRadius="12"
                                                Padding="12,9">
                                            <TextBlock x:Name="ProfileDateJoinedText"
                                                       Text="🗓️ 2026-05-08"
                                                       Foreground="White"
                                                       FontSize="16"/>
                                        </Border>
                                    </StackPanel>

                                    <Button Grid.Row="6"
                                            Width="55"
                                            Height="55"
                                            HorizontalAlignment="Right"
                                            Background="#3A0B2A"
                                            BorderThickness="0"
                                            Click="LogoutIcon_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="14">
                                                    <Image Source="/Frontend/Assets/logout.png"
                                                           Width="34"
                                                           Height="34"
                                                           Stretch="Uniform"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </Popup>


            </Grid>
        </Grid>

    </Grid>
</Window>